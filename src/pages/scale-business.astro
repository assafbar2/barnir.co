---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Scale Business — Execution | Assaf Barnir"
  description="Business leadership, team scaling, customer strategy. The Execution vertical."
  ogTitle="Scale Business — Execution"
  ogDescription="upgrAIde, barnirhired, GiFOC. CS leadership built from the ground up."
  ogImage="/og/scale-business.png"
>
  <section class="hero" style="min-height: 60vh;">
    <p class="hero-eyebrow">03 / Execution</p>
    <h1 class="hero-headline">Scale Business.</h1>
    <p class="hero-sub">
      Leadership, team scaling, customer strategy. Built pre and post-sales
      technical functions from the ground up.
    </p>
  </section>

  <section class="section" style="padding-top: 0;">
    <p class="section-label">Platforms</p>
    <div class="signal-grid">
      <a href="https://upgrai.de" class="signal-card" target="_blank" rel="noopener noreferrer"
         onclick="if(window.plausible)plausible('external_link',{props:{target:'upgrai.de'}})">
        <span class="signal-type">Platform</span>
        <h3 class="signal-title">upgrAIde</h3>
        <p class="signal-desc">AI upskilling platform for modern teams. Workshops and programs for customer-facing functions making the AI transition.</p>
        <span class="signal-link">upgrai.de →</span>
      </a>
      <a href="https://barnirhired.com" class="signal-card" target="_blank" rel="noopener noreferrer"
         onclick="if(window.plausible)plausible('external_link',{props:{target:'barnirhired.com'}})">
        <span class="signal-type">Site</span>
        <h3 class="signal-title">barnirhired</h3>
        <p class="signal-desc">CS hiring and talent strategy. 200+ people hired. First CS hire to world-class org — the whole range.</p>
        <span class="signal-link">barnirhired.com →</span>
      </a>
      <a href="https://gifoc.com" class="signal-card" target="_blank" rel="noopener noreferrer"
         onclick="if(window.plausible)plausible('external_link',{props:{target:'gifoc.com'}})">
        <span class="signal-type">Framework</span>
        <h3 class="signal-title">GiFOC</h3>
        <p class="signal-desc">Get in Front of Customers — the customer-facing leadership framework. Seek the ground truth, then act on it.</p>
        <span class="signal-link">gifoc.com →</span>
      </a>
    </div>

    <div style="margin-top: 64px;">
      <p class="section-label">Writing</p>
      <div class="signal-grid">
        <a href="https://barnir.substack.com/s/customer-success-ai-edition" class="signal-card" target="_blank" rel="noopener noreferrer">
          <span class="signal-type">Section</span>
          <h3 class="signal-title">Customer Success AI Edition</h3>
          <p class="signal-desc">GiFOC methodology, AI-era CS leadership. How customer success survives and wins the transition.</p>
          <span class="signal-link">Read →</span>
        </a>
        <a href="https://barnir.substack.com/s/ground-truth-support-ai" class="signal-card" target="_blank" rel="noopener noreferrer">
          <span class="signal-type">Section</span>
          <h3 class="signal-title">Ground Truth Support AI</h3>
          <p class="signal-desc">Seek the Ground Truth concept applied to support. Where AI and human judgment meet in customer-facing roles.</p>
          <span class="signal-link">Read →</span>
        </a>
      </div>
    </div>

    <div style="margin-top: 64px; text-align: center;">
      <a href="/work-with-me" class="btn-primary"
         onclick="if(window.plausible)plausible('cta_click',{props:{location:'scale-business'}})">
        Work with me
      </a>
    </div>
  </section>
</Layout>
