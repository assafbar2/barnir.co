---
import Layout from '../layouts/Layout.astro';
import { books } from '../data/books';

const featuredBook = books.find(b => b.isFeatured);
const regularBooks = books.filter(b => !b.isFeatured);
---

<Layout
  title="Library — Barnir"
  description="Four books by Barnir — AI support, emotions, mental models, and the human OS."
  ogTitle="Library — Barnir"
  ogDescription="Four books. One thesis. Written for people who don't want to be left behind."
  ogImage="/og/library.png"
>
  <section class="hero" style="min-height: 50vh;">
    <p class="hero-eyebrow">Library</p>
    <h1 class="hero-headline">Four books.<br />One thesis.</h1>
    <p class="hero-sub">
      I write for the people who don't want to be left behind —
      CS leaders whose support orgs haven't migrated yet,
      teams scaling under real pressure, and anyone in a world
      moving faster than the rules say it should.
    </p>
  </section>

  <section class="section" style="padding-top: 0;">

    {/* ── Featured book ── */}
    {featuredBook && (
      <>
        <p class="section-label">New release</p>
        <div
          id={featuredBook.title.toLowerCase().replace(/[:\s]+/g, '-').replace(/[^a-z0-9-]/g, '')}
          class="book-featured"
        >
          {featuredBook.badge && (
            <span class="featured-ribbon">{featuredBook.badge}</span>
          )}

          {/* Terminal "cover" placeholder */}
          <div class="featured-terminal">
            <div class="terminal-bar">
              <span class="terminal-dot terminal-dot--red"></span>
              <span class="terminal-dot terminal-dot--yellow"></span>
              <span class="terminal-dot terminal-dot--green"></span>
            </div>
            <div class="terminal-body">
              <p class="terminal-line"><span class="t-cmd">$ cat {featuredBook.title.toLowerCase().replace(/\s+/g, '-')}</span></p>
              <p class="terminal-line t-dim">───────────────────</p>
              <p class="terminal-line"><span class="t-key">title:    </span><span class="t-val">{featuredBook.title}</span></p>
              <p class="terminal-line"><span class="t-key">type:     </span><span class="t-val">book + AI skill</span></p>
              <p class="terminal-line"><span class="t-key">templates:</span><span class="t-val">{featuredBook.templates?.length ?? 0} included</span></p>
              <p class="terminal-line"><span class="t-key">license:  </span><span class="t-val">MIT + CC 4.0</span></p>
              <p class="terminal-line"><span class="t-key">price:    </span><span class="t-val">$0.00</span></p>
              <p class="terminal-line t-dim">───────────────────</p>
              <p class="terminal-line"><span class="t-cmd">$</span><span class="terminal-cursor"></span></p>
            </div>
          </div>

          {/* Content */}
          <div class="featured-content">
            <div class="featured-tags">
              {featuredBook.tags?.map((tag, i) => (
                <>
                  {i > 0 && <span class="featured-tag-sep">·</span>}
                  <span class="featured-tag">{tag}</span>
                </>
              ))}
              <span class="featured-badge">Free · Open Source</span>
            </div>

            <h2 class="featured-title">{featuredBook.title}</h2>
            {featuredBook.subtitle && (
              <p class="featured-subtitle">{featuredBook.subtitle}</p>
            )}
            {featuredBook.hook && (
              <p class="featured-hook">{featuredBook.hook}</p>
            )}
            {featuredBook.thesis && (
              <p class="featured-thesis">{featuredBook.thesis}</p>
            )}

            {/* set:html is intentional — featuredBook.description is static data in books.ts that may contain <strong> tags. Never source from user input or CMS without sanitization. */}
            <p class="featured-desc" set:html={featuredBook.description} />

            {featuredBook.templates && featuredBook.templates.length > 0 && (
              <div class="featured-pills">
                {featuredBook.templates.map(t => (
                  <span class="featured-pill">{t}</span>
                ))}
              </div>
            )}

            <div class="featured-links">
              {featuredBook.ctaLinks?.map(link => (
                link.primary ? (
                  <a href={link.url} class="btn-featured-primary" target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                ) : (
                  <a href={link.url} class="btn-featured-secondary" target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                )
              ))}
              <span class="featured-free">Free forever</span>
            </div>
          </div>
        </div>
      </>
    )}

    {/* ── Regular books ── */}
    <p class="section-label" style="margin-top: 64px;">Also by Barnir</p>

    <div class="book-list">
      {regularBooks.map((book, i) => (
        <div
          id={book.title.toLowerCase().replace(/[:\s]+/g, '-').replace(/[^a-z0-9-]/g, '')}
          class="book-card"
        >
          <div class="book-cover-wrap">
            {book.cover ? (
              <img
                src={book.cover}
                alt={`${book.title} cover`}
                class="book-cover-img"
                width="160"
                height="160"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : undefined}
                decoding="async"
              />
            ) : (
              <div class="book-cover-placeholder">
                <span class="book-cover-placeholder-title">{book.title}</span>
                {book.subtitle && (
                  <span class="book-cover-placeholder-sub">{book.subtitle}</span>
                )}
              </div>
            )}
            {book.badge && (
              <span class="book-badge">{book.badge}</span>
            )}
          </div>

          <div class="book-meta">
            <div class="book-tags">
              {book.tags?.map((tag, j) => (
                <>
                  {j > 0 && <span class="book-tag-sep">·</span>}
                  <span class="book-tag">{tag}</span>
                </>
              ))}
            </div>

            <h2 class="book-title">{book.title}</h2>
            {book.subtitle && (
              <p class="book-subtitle">{book.subtitle}</p>
            )}
            {book.hook && (
              <p class="book-hook">{book.hook}</p>
            )}

            {/* set:html is intentional — book.description is static data in books.ts that may contain <strong> tags. Never source from user input or CMS without sanitization. */}
            <p class="book-desc" set:html={book.description} />

            {book.testimonial && (
              <blockquote class="book-testimonial">
                <p>"{book.testimonial.text}"</p>
                <cite>— {book.testimonial.author}</cite>
              </blockquote>
            )}

            <div class="book-links">
              {book.buyLinks?.amazon && (
                <a href={book.buyLinks.amazon} class="btn-book-primary" target="_blank" rel="noopener noreferrer">
                  Amazon →
                </a>
              )}
              {book.buyLinks?.google && (
                <a href={book.buyLinks.google} class="btn-book-secondary" target="_blank" rel="noopener noreferrer">
                  Google Books
                </a>
              )}
              {book.buyLinks?.audible && (
                <a href={book.buyLinks.audible} class="btn-book-secondary" target="_blank" rel="noopener noreferrer">
                  Audible
                </a>
              )}
              {book.buyLinks?.other?.map(link => (
                <a href={link.url} class="btn-book-secondary" target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              ))}
              {book.note && (
                <span class="book-note">{book.note}</span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* ── Substack — unchanged ── */}
    <div style="margin-top: 64px; border-top: 1px solid var(--border); padding-top: 48px;">
      <p class="section-label">Long-form writing</p>
      <h2 class="section-title" style="font-size: 28px;">Substack</h2>
      <p style="font-size: 15px; color: var(--text-muted); margin-bottom: 24px;">
        Three sections, one newsletter hub.
      </p>
      <div class="signal-grid">
        <a href="https://barnir.substack.com" class="signal-card" target="_blank" rel="noopener noreferrer">
          <span class="signal-type">Newsletter</span>
          <h3 class="signal-title">The Barnir OS Update</h3>
          <p class="signal-desc">Main newsletter — the whole OS view.</p>
          <span class="signal-link">Subscribe →</span>
        </a>
        <a href="https://barnir.substack.com/s/the-ai-upgrade" class="signal-card" target="_blank" rel="noopener noreferrer">
          <span class="signal-type">Section</span>
          <h3 class="signal-title">The AI Upgrade</h3>
          <p class="signal-desc">AI tools and technology — Scale Intelligence section.</p>
          <span class="signal-link">Read →</span>
        </a>
        <a href="https://barnir.substack.com/s/customer-success-ai-edition" class="signal-card" target="_blank" rel="noopener noreferrer">
          <span class="signal-type">Section</span>
          <h3 class="signal-title">Customer Success AI Edition</h3>
          <p class="signal-desc">AI's Role in Crafting Tomorrow's Customer Wins.</p>
          <span class="signal-link">Read →</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Featured card ── */
  .book-featured {
    background: var(--bg-card);
    border: 1px solid var(--green-dim);
    border-radius: var(--radius-lg);
    padding: 40px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: start;
    position: relative;
  }
  .featured-ribbon {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--green);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .featured-terminal {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    font-family: var(--font-mono);
  }
  .terminal-bar {
    display: flex;
    gap: 6px;
    margin-bottom: 16px;
  }
  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-hover);
  }
  .terminal-dot--red { background: #ff5f57; }
  .terminal-dot--yellow { background: #febc2e; }
  .terminal-dot--green { background: #28c840; }
  .terminal-body { display: flex; flex-direction: column; gap: 2px; }
  .terminal-line {
    font-size: 11px;
    line-height: 1.8;
    color: var(--text-dim);
  }
  .t-cmd { color: var(--green); }
  .t-key { color: var(--text-muted); }
  .t-val { color: var(--text); }
  .t-dim { color: var(--text-dim); }
  .terminal-cursor {
    display: inline-block;
    width: 7px;
    height: 12px;
    background: var(--green);
    vertical-align: middle;
    margin-left: 2px;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .terminal-cursor { animation: none; }
  }
  .featured-tags {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .featured-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .featured-tag-sep { color: var(--border-hover); font-size: 10px; }
  .featured-badge {
    background: var(--green-dim);
    color: var(--green);
    border: 1px solid var(--green-dim);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .featured-title {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin-bottom: 4px;
  }
  .featured-subtitle {
    font-size: 14px;
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: 12px;
  }
  .featured-hook {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--green);
    font-style: italic;
    margin-bottom: 16px;
  }
  .featured-thesis {
    font-size: 15px;
    color: var(--text);
    font-weight: 500;
    border-left: 3px solid var(--green);
    padding-left: 16px;
    margin-bottom: 18px;
    line-height: 1.5;
  }
  .featured-desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 20px;
  }
  .featured-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .featured-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 20px;
  }
  .featured-pill::before { content: '✓ '; color: var(--green); }
  .featured-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  .btn-featured-primary {
    font-size: 13px;
    font-weight: 600;
    background: var(--green);
    color: var(--bg);
    padding: 9px 20px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: opacity var(--transition);
  }
  .btn-featured-primary:hover { opacity: 0.85; }
  .btn-featured-primary:focus-visible { outline: 2px solid var(--green); outline-offset: 2px; }
  .btn-featured-secondary {
    font-size: 12px;
    color: var(--text-muted);
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color var(--transition), color var(--transition);
  }
  .btn-featured-secondary:hover { color: var(--text); border-color: var(--border-hover); }
  .btn-featured-secondary:focus-visible { outline: 2px solid var(--green); outline-offset: 2px; }
  .featured-free {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--green);
    margin-left: 4px;
  }
  /* ── Regular book list ── */
  .book-list { display: flex; flex-direction: column; }
  .book-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 40px;
    align-items: start;
    padding: 40px 0;
  }
  .book-card + .book-card { border-top: 1px solid var(--border); }
  .book-cover-wrap { position: relative; }
  .book-cover-img {
    width: 160px;
    height: 160px;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: block;
  }
  .book-cover-placeholder {
    width: 160px;
    height: 160px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px;
    gap: 8px;
  }
  .book-cover-placeholder-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
    text-align: center;
    line-height: 1.4;
  }
  .book-cover-placeholder-sub {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-dim);
    text-align: center;
    line-height: 1.4;
  }
  .book-badge {
    position: absolute;
    top: -8px;
    left: -8px;
    background: var(--green);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    padding: 3px 7px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .book-tags { display: flex; align-items: center; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
  .book-tag { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; }
  .book-tag-sep { color: var(--border-hover); font-size: 10px; }
  .book-title { font-size: 22px; font-weight: 700; letter-spacing: -0.01em; line-height: 1.2; margin-bottom: 2px; }
  .book-subtitle { font-size: 13px; color: var(--text-muted); margin-bottom: 10px; font-style: italic; }
  .book-hook { font-family: var(--font-mono); font-size: 12px; color: var(--green); font-style: italic; margin-bottom: 14px; margin-top: 6px; }
  .book-desc { font-size: 14px; color: var(--text-muted); line-height: 1.75; margin-bottom: 20px; }
  .book-desc strong { color: var(--text); font-weight: 500; }
  .book-testimonial { border-left: 2px solid var(--border); padding: 6px 0 6px 16px; margin-bottom: 20px; }
  .book-testimonial p { font-size: 12px; color: var(--text-muted); font-style: italic; line-height: 1.6; margin-bottom: 4px; }
  .book-testimonial cite { font-size: 11px; color: var(--text-dim); font-style: normal; }
  .book-links { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .btn-book-primary { font-size: 12px; font-weight: 600; background: var(--text); color: var(--bg); padding: 7px 16px; border-radius: var(--radius); text-decoration: none; transition: background var(--transition); }
  .btn-book-primary:hover { background: var(--green); }
  .btn-book-primary:focus-visible { outline: 2px solid var(--green); outline-offset: 2px; }
  .btn-book-secondary { font-size: 12px; color: var(--text-muted); padding: 7px 12px; border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; transition: border-color var(--transition), color var(--transition); }
  .btn-book-secondary:hover { color: var(--text); border-color: var(--border-hover); }
  .btn-book-secondary:focus-visible { outline: 2px solid var(--green); outline-offset: 2px; }
  .book-note { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); margin-left: 4px; }
  /* ── Responsive ── */
  @media (max-width: 640px) {
    .book-featured { grid-template-columns: 1fr; gap: 24px; }
    .book-card { grid-template-columns: 1fr; gap: 20px; }
    .book-cover-wrap { margin: 0 auto; }
    .book-cover-img, .book-cover-placeholder { width: 120px; height: 120px; }
  }
</style>
