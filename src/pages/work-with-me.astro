---
import Layout from '../layouts/Layout.astro';

const CONTACT = 'mailto:barnir@agentmail.to?subject=Let%27s%20work%20together';
---

<Layout
  title="Work with Assaf Barnir — Unscared OS"
  description="Board advisory. Team building. AI strategy. Leadership coaching. Let's build something together."
  ogTitle="Work with Assaf Barnir"
  ogDescription="Board advisory. Team building. AI strategy. Leadership coaching."
  ogImage="/og/work-with-me.png"
>
  <script is:inline type="application/ld+json" slot="head">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How can I work with Assaf Barnir?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Assaf Barnir is available for board advisory, AI strategy, CS team building, and leadership coaching. He works with leaders and teams on AI strategy, pre and post-sales technical org building, and execution. Reach him at barnir@agentmail.to or via barnir.co/work-with-me."
        }
      },
      {
        "@type": "Question",
        "name": "What does Assaf Barnir offer for CS team building?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Assaf Barnir helps companies build Customer Success, Solutions Engineering, Support, and Technical Account Management teams from the ground up — from the first CS hire to a world-class org. He has hired 200+ people in customer-facing roles."
        }
      },
      {
        "@type": "Question",
        "name": "What AI strategy services does Assaf Barnir provide?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Assaf Barnir provides AI strategy through the upgrAIde platform and direct advisory engagements. His approach focuses on how specific teams compound with AI — not generic AI adoption, but targeted upskilling and infrastructure for customer-facing organizations."
        }
      }
    ]
  }</script>
  <section class="hero" style="min-height: 80vh;">
    <p class="hero-eyebrow">Work with me</p>
    <h1 class="hero-headline">Let's build something.</h1>
    <p class="hero-sub">
      Ownership via doing. AI strategy, CS scaling, and engine tuning.
      I build the systems that execute, not the slides that sit there. No fluff, just outcomes.
    </p>
    <div class="hero-actions" style="margin-top: 40px;">
      <a href={CONTACT} class="btn-primary"
         onclick="if(window.plausible)plausible('cta_click',{props:{location:'work-with-me-hero'}})">
        Email me
      </a>
    </div>
  </section>

  <section class="section">
    <div class="verticals-grid" style="max-width: 800px;">
      <div class="vertical-card">
        <span class="vertical-icon">Board</span>
        <h3 class="vertical-name">Board & Advisory</h3>
        <p class="vertical-desc">
          Joining smaller, cooler boards where the work actually matters.
          Bring me in where AI strategy, customer-facing execution, and team scaling are the needle movers.
        </p>
      </div>
      <div class="vertical-card">
        <span class="vertical-icon">Team</span>
        <h3 class="vertical-name">CS Team Building</h3>
        <p class="vertical-desc">
          From first CS hire to world-class org. Pre and post-sales technical functions —
          Customer Success, Solutions Engineering, Support, TAM.
        </p>
      </div>
      <div class="vertical-card">
        <span class="vertical-icon">AI</span>
        <h3 class="vertical-name">AI Strategy</h3>
        <p class="vertical-desc">
          Not the "AI for everyone" kind. The "here's exactly how your team
          compounds with AI" kind. via upgrAIde.co workshops or direct engagement.
        </p>
      </div>
    </div>

    <div style="margin-top: 64px; text-align: center;">
      <a href={CONTACT} class="btn-primary"
         onclick="if(window.plausible)plausible('cta_click',{props:{location:'work-with-me-bottom'}})">
        Start a conversation
      </a>
      <p style="margin-top: 16px; font-size: 13px; color: var(--text-dim);">
        barnir@agentmail.to <span style="opacity:0.5;">— Me + AI Mailbox</span>
      </p>
    </div>
  </section>
</Layout>
