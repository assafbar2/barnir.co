---
import Layout from '../layouts/Layout.astro';
import CLI from '../components/CLI';
import { whatsNew } from '../data/whats-new';

const CONTACT = 'mailto:barnir@agentmail.to?subject=Let%27s%20work%20together';
---

<Layout>
  <script is:inline type="application/ld+json" slot="head">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Who is Assaf Barnir?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Assaf Barnir is an engineer and customer success leader who builds pre and post-sales technical teams from the ground up — Customer Success, Solutions Engineering, Support, and Technical Account Management. He has hired 200+ people, built 13+ products, and written 4 books. He helps leaders and teams perform in the AI era through the Unscared OS framework at barnir.co."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Unscared OS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Unscared OS is Assaf Barnir's framework for human performance alongside AI. It runs across three verticals: Scale Yourself (Human OS — wellness tools and mental models), Scale Intelligence (AI Stack — tools and infrastructure), and Scale Business (Execution — leadership and team scaling). The thesis: performance = Human OS + AI Stack + Execution."
        }
      },
      {
        "@type": "Question",
        "name": "How can CS leaders and customer-facing teams navigate the AI transition?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Assaf Barnir works with CS leaders and customer-facing teams through direct advisory, the upgrAIde platform, and workshops. His approach: build AI strategy from the ground up, not bolt it on. Contact: barnir@agentmail.to."
        }
      },
      {
        "@type": "Question",
        "name": "What is the GiFOC framework?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "GiFOC (Get in Front of Customers) is a leadership framework developed by Assaf Barnir for customer-facing teams. The principle: seek ground truth directly from customers, then act on it. Available at gifoc.com."
        }
      },
      {
        "@type": "Question",
        "name": "What books has Assaf Barnir written?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Assaf Barnir has written four books: UNSCARED: AI (living alongside AI without fear, at unscaredai.com), Emotions Soup (understanding the internal signals driving your decisions, on Amazon), Beyond the Rules (mental models for independent thinkers, on Amazon), and UNSCARED: The Machine Shift (a systematic guide to the AI migration, coming soon). All books at barnir.co/library."
        }
      },
      {
        "@type": "Question",
        "name": "What is Agent Switchboard?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Agent Switchboard is a multi-agent routing platform built by Assaf Barnir that enables learning, finding, routing, and orchestrating AI agents at scale. Available at agentswitchboard.dev."
        }
      },
      {
        "@type": "Question",
        "name": "How can I work with Assaf Barnir?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Assaf Barnir works in the trenches on AI strategy, CS team building, and leadership under real operating pressure. Reach him at barnir@agentmail.to or via barnir.co/work-with-me."
        }
      }
    ]
  }</script>
  <!-- ── Hero ─────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-eyebrow">
      <img src="/Assaf.jpg" alt="Assaf Barnir" class="hero-avatar" />
      <span>Unscared OS</span>
    </div>

    <h1 class="hero-headline">
      Don't adapt to AI.<br />Architect for it.
    </h1>

    <p class="hero-sub">
    I engineered the Unscared OS to equip humans with the AI infrastructure, cognitive frameworks, 
    and human resilience required to execute alongside machines—without fear.
    </p>

    <!-- Equation -->
    <div class="hero-equation" aria-label="performance = Human OS + AI Stack + Execution">
      <span class="eq-result">performance</span>
      <span class="eq-equals">=</span>
      <span class="eq-var">Human OS</span>
      <span class="eq-op">+</span>
      <span class="eq-var">AI Stack</span>
      <span class="eq-op">+</span>
      <span class="eq-var">Execution</span>
    </div>

    <!-- CLI Terminal (desktop) -->
    <CLI client:load />

    <!-- Mobile fallback -->
    <div class="cli-mobile-fallback">
      <p class="cli-mobile-title">OS Commands</p>
      <div class="cli-mobile-buttons">
        <a href="/scale-yourself" class="cli-mobile-btn">/scale-yourself</a>
        <a href="/scale-intelligence" class="cli-mobile-btn">/scale-intelligence</a>
        <a href="/scale-business" class="cli-mobile-btn">/scale-business</a>
        <a href="/work-with-me" class="cli-mobile-btn">/hire</a>
        <a href="/about" class="cli-mobile-btn">/about</a>
        <a href="/library" class="cli-mobile-btn">/books</a>
      </div>
    </div>

    <div class="hero-actions">
      <a
        href="/work-with-me"
        class="btn-primary"
        onclick="if(window.plausible)plausible('cta_click',{props:{location:'hero'}})"
      >Work with me</a>
      <a href="/about" class="btn-ghost">Learn more</a>
    </div>
  </section>

  <!-- ── The Three Verticals ────────────────────── -->
  <section class="verticals">
    <div class="section">
      <p class="section-label">Three verticals</p>
      <h2 class="section-title">Scale in every direction</h2>
      <p class="section-sub">
        One person, three distinct bodies of work — each with its own tooling,
        writing, and products.
      </p>

      <div class="verticals-grid">
        <!-- Scale Yourself -->
        <a href="/scale-yourself" class="vertical-card">
          <span class="vertical-icon">01 / Human OS</span>
          <h3 class="vertical-name">Scale<br />Yourself</h3>
          <p class="vertical-desc">
            Wellness tools, mental models, emotional intelligence. The software
            that runs underneath everything else.
          </p>
          <div class="vertical-products">
            <span class="vertical-tag">Vessel</span>
            <span class="vertical-tag">Nuudge</span>
            <span class="vertical-tag">Gram-Reaper</span>
            <span class="vertical-tag">Emotions Soup</span>
            <span class="vertical-tag">Beyond the Rules</span>
          </div>
          <span class="vertical-link">Explore →</span>
        </a>

        <!-- Scale Intelligence -->
        <a href="/scale-intelligence" class="vertical-card">
          <span class="vertical-icon">02 / AI Stack</span>
          <h3 class="vertical-name">Scale<br />Intelligence</h3>
          <p class="vertical-desc">
            AI tools, technical infrastructure, developer output. The machinery
            that makes thinking leverage-able.
          </p>
          <div class="vertical-products">
            <span class="vertical-tag">Agent Switchboard</span>
            <span class="vertical-tag">GitHub</span>
            <span class="vertical-tag">The AI Upgrade</span>
          </div>
          <span class="vertical-link">Explore →</span>
        </a>

        <!-- Scale Business -->
        <a href="/scale-business" class="vertical-card">
          <span class="vertical-icon">03 / Execution</span>
          <h3 class="vertical-name">Scale<br />Business</h3>
          <p class="vertical-desc">
            Leadership, team scaling, customer strategy. Built pre and post-sales
            technical functions from the ground up.
          </p>
          <div class="vertical-products">
            <span class="vertical-tag">upgrAIde</span>
            <span class="vertical-tag">barnirhired</span>
            <span class="vertical-tag">GiFOC</span>
            <span class="vertical-tag">Workshops</span>
          </div>
          <span class="vertical-link">Explore →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Recent Signal ──────────────────────────── -->
  <section class="section">
    <p class="section-label">Recent signal</p>
    <h2 class="section-title">What's shipping</h2>
    <p class="section-sub">Latest post, latest build, latest book.</p>

    <div class="signal-grid">
      {whatsNew.map((item) => (
        <a
          href={item.url}
          class="signal-card"
          target={item.url.startsWith('http') ? '_blank' : undefined}
          rel={item.url.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          <span class="signal-type">{item.label}</span>
          <h3 class="signal-title">{item.title}</h3>
          <p class="signal-desc">{item.description}</p>
          <span class="signal-link">Read →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Credentials ────────────────────────────── -->
  <section class="credentials">
    <div class="section">
      <div class="cred-inner">
        <div>
          <div class="cred-stats">
            <div>
              <div class="stat-number">200+</div>
              <div class="stat-label">People hired</div>
            </div>
            <div>
              <div class="stat-number">4<span style="font-size:0.5em;vertical-align:super;">*</span></div>
              <div class="stat-label">Books</div>
            </div>
            <div>
              <div class="stat-number">13+</div>
              <div class="stat-label">Products built</div>
            </div>
          </div>
        </div>

        <div>
          <p class="section-label">Who is this</p>
          <p class="cred-text">
            I'm an engineer who's built pre- and post-sales technical teams from the ground up —
            Customer Success, Solutions Engineering, Support, and Technical Account Management.
            I've been the first CS hire, helped companies make their <strong>first CS hire</strong>,
            and scaled those functions into world-class orgs. I know what the table looks like from
            every side. Now I'm building for the AI era, <strong>without fear</strong>.
          </p>
          <div class="cred-links">
            <a href="/about" class="btn-ghost" style="padding: 9px 18px; font-size: 13px;">Full story</a>
            <a
              href="/work-with-me"
              class="btn-primary"
              style="padding: 9px 18px; font-size: 13px;"
              onclick="if(window.plausible)plausible('cta_click',{props:{location:'credentials'}})"
            >Work together</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA Strip ──────────────────────────────── -->
  <section class="cta-strip">
    <h2 class="cta-strip-title">Let's build something.</h2>
    <div class="cta-strip-lines">
      <p>▎ Slides don't ship. I do.</p>
      <p>▎ AI | CS | Leadership</p>
    </div>
    <div class="hero-actions">
      <a
        href="/work-with-me"
        class="btn-primary"
        onclick="if(window.plausible)plausible('cta_click',{props:{location:'cta-strip'}})"
      >Work with me</a>
      <a href={CONTACT} class="btn-ghost">Email directly</a>
    </div>
  </section>
</Layout>
