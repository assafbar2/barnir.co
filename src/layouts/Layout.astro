---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = 'Assaf Barnir — Unscared OS',
  description = 'Unscared OS equips humans with AI infrastructure, human wellness tools, and mental models so they can lead alongside AI — without fear.',
  ogTitle = 'Assaf Barnir — Unscared OS',
  ogDescription = 'Three verticals. One thesis: performance = Human OS + AI Stack + Execution.',
  ogImage = '/og/homepage.png',
  canonicalUrl,
} = Astro.props;

const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OG / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={`https://barnir.co${ogImage}`} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={`https://barnir.co${ogImage}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme: apply saved preference before paint to avoid flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <!-- Plausible analytics -->
    <script
      defer
      data-domain="barnir.co"
      src="https://plausible.io/js/script.js"
    ></script>
  </head>
  <body>
    <nav class="nav" role="navigation" aria-label="Main navigation">
      <a href="/" class="nav-brand">barnir<span>.co</span></a>
      <ul class="nav-links">
        <li><a href="/scale-yourself">Scale Yourself</a></li>
        <li><a href="/scale-intelligence">Scale Intelligence</a></li>
        <li><a href="/scale-business">Scale Business</a></li>
        <li><a href="/library">Library</a></li>
        <li><a href="/about">About</a></li>
        <li>
          <a
            href="/work-with-me"
            class="nav-cta"
            onclick="if(window.plausible)plausible('cta_click',{props:{location:'nav'}})"
          >Work with me</a>
        </li>
        <li>
          <button
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Toggle light/dark mode"
            type="button"
          >
            <!-- Moon: shown in dark mode -->
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <!-- Sun: shown in light mode -->
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
        </li>
      </ul>
    </nav>

    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="footer" role="contentinfo">
      <span class="footer-brand">barnir<span>.co</span> — Unscared OS</span>
      <ul class="footer-links">
        <li><a href="/scale-yourself">Scale Yourself</a></li>
        <li><a href="/scale-intelligence">Scale Intelligence</a></li>
        <li><a href="/scale-business">Scale Business</a></li>
        <li><a href="/library">Library</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/work-with-me">Work with me</a></li>
      </ul>
    </footer>
  </body>
</html>
